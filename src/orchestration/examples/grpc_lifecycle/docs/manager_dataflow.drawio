                <mxCell id="title" value="grpc_lifecycle/src/manager.rs - Structured Data Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1" parent="1" vertex="1">
