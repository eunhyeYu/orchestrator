                <mxCell id="subtitle" value="Trigger → Manager Method → Internal State → External I/O → Output" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#666666" parent="1" vertex="1">
                    <mxGeometry x="500" y="58" width="920" height="24" as="geometry"/>
