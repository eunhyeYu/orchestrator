                    <mxGeometry x="1480" y="328" width="380" height="90" as="geometry"/>
                </mxCell>

                <mxCell id="r3_label" value="Flow C: get_status()" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="52" y="458" width="220" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="r3_trig" value="StatusFilter&#xa;(All / Pid / InstanceId / ServiceName)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="60" y="488" width="240" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r3_logic" value="get_status()&#xa;1) select matching instances&#xa;2) map RuntimeState → ProcessStatus&#xa;3) read proc state/memory for Running" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="345" y="488" width="380" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r3_state" value="Read state&#xa;• instances&#xa;• pid_to_instance&#xa;• runtime state (Running/PendingRestart)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#ffe0b2;strokeColor=#ef6c00;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="800" y="488" width="370" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r3_ext" value="Read /proc/{pid}/stat, statm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8bbd0;strokeColor=#ad1457;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1240" y="488" width="220" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="r3_out" value="Vec&lt;ProcessStatus&gt; (+ ManagerStats via caller)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1c4e9;strokeColor=#5e35b1;fontStyle=1;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1480" y="488" width="380" height="90" as="geometry"/>
                </mxCell>

                <mxCell id="r4_label" value="Flow D: check_and_reap() (periodic)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="52" y="618" width="300" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="r4_trig" value="Periodic monitor tick&#xa;(from server_kyron monitor_task)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#90caf9;strokeColor=#1565c0;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="60" y="648" width="240" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r4_logic" value="check_and_reap()&#xa;1) detect exited children via try_wait()&#xa;2) classify Completed/Crashed&#xa;3) should_restart(policy, crashed, restart_count)&#xa;4) PendingRestart → respawn when due&#xa;5) apply spawn_fail_count limit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#2e7d32;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="345" y="648" width="380" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r4_state" value="Read/Write state&#xa;• instances (state transitions)&#xa;• pid_to_instance updates&#xa;• service_to_instances cleanup&#xa;• stats(crashed/completed/restarted/started)&#xa;• history append (Crashed/Completed/Restart*)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#ffe0b2;strokeColor=#ef6c00;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="800" y="648" width="370" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r4_ext" value="OS: wait + respawn Child process&#xa;Logger thread: JSONL append via mpsc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1240" y="648" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r4_out" value="No direct API return&#xa;(effects reflected in later status/stats queries)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1c4e9;strokeColor=#5e35b1;fontStyle=1;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1480" y="648" width="380" height="90" as="geometry"/>
                </mxCell>

                <mxCell id="shared_state" value="Shared components (used across flows)&#xa;• ManagedInstance { instance_id, service_name, binary_path, args, restart_policy, restart_count, state }&#xa;• RuntimeState = Running | PendingRestart&#xa;• history bounded by max_history_size" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ff8f00;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="345" y="788" width="825" height="130" as="geometry"/>
