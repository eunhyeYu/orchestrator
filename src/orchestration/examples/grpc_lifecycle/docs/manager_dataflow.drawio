                <mxCell id="r1_label" value="Flow A: start_binary()" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="52" y="138" width="220" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="r1_trig" value="StartRequest&#xa;(service_name, binary_path, args, restart_policy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="60" y="168" width="240" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r1_logic" value="start_binary()&#xa;1) validate path&#xa;2) derive/check service_name&#xa;3) spawn_process(binary_path, args)&#xa;4) create ManagedInstance(state=Running)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="345" y="168" width="380" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r1_state" value="Write state maps&#xa;• instances[instance_id] = ManagedInstance&#xa;• pid_to_instance[pid] = instance_id&#xa;• service_to_instances[service] += instance_id&#xa;• stats.total_started++&#xa;• push_history(Started)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#ffe0b2;strokeColor=#ef6c00;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="800" y="168" width="370" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r1_ext" value="OS: spawn new Child process" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1240" y="168" width="220" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="r1_out" value="StartResult&#xa;(success, pid, instance_id, service_name, message)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1c4e9;strokeColor=#5e35b1;fontStyle=1;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1480" y="168" width="380" height="90" as="geometry"/>
                </mxCell>

                <mxCell id="r2_label" value="Flow B: stop_binary()" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="52" y="298" width="220" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="r2_trig" value="StopRequest&#xa;(target, mode, timeout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="60" y="328" width="240" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r2_logic" value="stop_binary()&#xa;1) resolve_target_to_instance_ids()&#xa;2) graceful_stop() or force_stop()&#xa;3) remove instances from maps&#xa;4) push_history(Stopped)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="345" y="328" width="380" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r2_state" value="Update state maps&#xa;• instances remove&#xa;• pid_to_instance remove&#xa;• service_to_instances cleanup&#xa;• stats.total_stopped++&#xa;• history append" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#ffe0b2;strokeColor=#ef6c00;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="800" y="328" width="370" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r2_ext" value="OS: SIGTERM/SIGKILL + wait" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1240" y="328" width="220" height="40" as="geometry"/>
